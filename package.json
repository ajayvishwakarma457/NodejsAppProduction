{
  "name": "nodejs-production-roadmap",
  "version": "1.0.0",
  "description": "Implementation of the Node.js Production Roadmap",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:seed": "node src/db/seeder.js",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "start:gateway": "node microservices/api-gateway/index.js",
    "start:user": "node microservices/user-service/index.js",
    "start:notif": "node microservices/notification-service/index.js",
    "start:microservices": "concurrently -n gateway,user,notif \"npm run start:gateway\" \"npm run start:user\" \"npm run start:notif\"",
    "profile:doctor": "clinic doctor -- node src/server.js",
    "profile:flame": "clinic flame -- node src/server.js",
    "profile:bubbleprof": "clinic bubbleprof -- node src/server.js",
    "profile:0x": "0x src/server.js",
    "load:autocannon": "autocannon -c 50 -d 5 -m POST -b '{\"number\":15}' -H 'x-user-id: load_user' -H 'Content-Type: application/json' http://localhost:5000/api/v1/jobs/heavy-cpu",
    "load:artillery": "artillery run tests/load/artillery-config.yml",
    "load:k6": "k6 run tests/load/k6-script.js",
    "monitoring:start": "docker compose -f monitoring/docker-compose.monitoring.yml up -d",
    "monitoring:stop": "docker compose -f monitoring/docker-compose.monitoring.yml down",
    "monitoring:logs": "docker compose -f monitoring/docker-compose.monitoring.yml logs -f",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\" \"serverless/**/*.js\"",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.js": "eslint --fix"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.967.0",
    "@aws-sdk/client-secrets-manager": "^3.967.0",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@prisma/client": "^6.19.3",
    "amqplib": "^2.0.1",
    "awilix": "^13.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "busboy": "^1.6.0",
    "concurrently": "^9.2.1",
    "connect-redis": "^6.1.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-http-proxy": "^2.1.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.24.0",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "nats": "^2.29.3",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "opossum": "^8.5.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^5.0.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "unleash-client": "^6.8.0",
    "winston": "^3.19.0",
    "winston-loki": "^6.1.4",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^25.9.1",
    "@types/swagger-ui-express": "^4.1.8",
    "0x": "^6.0.0",
    "artillery": "^2.0.21",
    "autocannon": "^8.0.0",
    "clinic": "^13.0.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
